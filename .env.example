# HoldMe environment variables
# Copy to .env and fill in values. Never commit .env.

# ── Frontend ─────────────────────────────────────────────────────────────────
# Chain ID: 31337 = Anvil local, 84532 = Base Sepolia, 8453 = Base mainnet
NEXT_PUBLIC_CHAIN_ID=84532

# Deployed HoldMeVault contract address (fill in after deploy)
NEXT_PUBLIC_HOLDME_CONTRACT_ADDRESS=

# USDC token address on the target chain
# Anvil local:   address printed by LocalDeploy script
# Base Sepolia:  address of your testnet USDC (MockUSDC or Circle testnet USDC)
# Base mainnet:  0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
NEXT_PUBLIC_USDC_ADDRESS=

# WalletConnect Cloud project ID (https://cloud.walletconnect.com)
# Optional — omit to disable WalletConnect, injected wallet still works
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Deployment ────────────────────────────────────────────────────────────────
# Deployer private key — BURNER WALLET ONLY.
# This must be a fresh wallet created solely for deployment.
# Never use your Phantom wallet or any hot wallet that holds real funds.
# Never paste any private key into chat or share it with anyone.
# Never commit this value to version control.
PRIVATE_KEY=

# RPC endpoints
BASE_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# HoldMeVault constructor arguments
# Wallet that receives the upfront hold fee
FEE_RECIPIENT_ADDRESS=0xB8166521a602bF4Dd4748D76864Dc06336EB5729

# USDC address used by Deploy.s.sol (testnet/mainnet deploys)
# Not needed for LocalDeploy.s.sol — it deploys MockUSDC itself
USDC_ADDRESS=

# Optional: wallet to receive minted USDC during local deploy (defaults to FEE_RECIPIENT_ADDRESS)
MINT_TO=
